function a11ytalks_preprocess_node(array &$variables): void {

}

/**
 * Implements hook_preprocess_HOOK() for block--system-branding-block.html.twig.
 */
function a11ytalks_preprocess_block__system_branding_block(array &$variables): void {
  $variables['is_front'] = \Drupal::service('path.matcher')->isFrontPage();
}
